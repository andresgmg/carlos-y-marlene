---
import Layout from '../layouts/Layout.astro';

const photos = [
  { caption: 'Nuestra primera foto juntos', shade: '#e8cdd0' },
  { caption: 'Vacaciones en la playa',       shade: '#d4b8bb' },
  { caption: 'Cumpleaños de Carlos',          shade: '#c8a8ac' },
  { caption: 'Tarde de otoño en el parque',   shade: '#e0c4c8' },
  { caption: 'La propuesta de matrimonio',    shade: '#f0d8da' },
  { caption: 'Festejando con la familia',     shade: '#d8bcbf' },
  { caption: 'Viaje a la montaña',            shade: '#cdb0b4' },
  { caption: 'Nuestra sesión de fotos',       shade: '#e4cdd0' },
  { caption: 'Preparativos de la boda',       shade: '#dac0c4' },
];
---

<Layout
  title="Galería — Carlos y Marlene"
  description="Momentos especiales de Carlos y Marlene a lo largo de su historia de amor."
>
  <section class="page-hero">
    <div class="container">
      <h1>Galería</h1>
      <p class="page-subtitle">Momentos que guardaremos en el corazón para siempre.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Nuestros momentos</h2>
      <span class="section-divider"></span>

      <div class="gallery-grid">
        {photos.map((photo) => (
          <figure class="gallery-item" style={`background-color:${photo.shade};`}>
            <div class="gallery-placeholder" aria-hidden="true">
              <span class="gallery-icon">📷</span>
            </div>
            <figcaption class="gallery-caption">{photo.caption}</figcaption>
          </figure>
        ))}
      </div>

      <p class="gallery-note">
        Pronto añadiremos nuestras fotos favoritas. ¡Vuelve a visitarnos!
      </p>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(160deg, var(--color-blush) 0%, var(--color-cream) 100%);
    padding: 5rem 1.5rem 3rem;
    text-align: center;
  }

  .page-hero h1 { font-size: clamp(2.2rem, 6vw, 4rem); margin-bottom: 1rem; }

  .page-subtitle {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-accent);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .gallery-item {
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 16px rgba(61, 43, 31, 0.1);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(61, 43, 31, 0.18);
  }

  .gallery-placeholder {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-icon { font-size: 3rem; opacity: 0.5; }

  .gallery-caption {
    background: rgba(255,255,255,0.85);
    padding: 0.8rem 1rem;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-dark);
    text-align: center;
    border-top: 1px solid rgba(61,43,31,0.08);
  }

  .gallery-note {
    text-align: center;
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-accent);
    font-size: 1.05rem;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Confirmar Asistencia — Carlos y Marlene"
  description="Confirma tu asistencia a la boda de Carlos y Marlene. ¡Tu presencia es el mejor regalo!"
>
  <section class="page-hero">
    <div class="container">
      <h1>Confirma tu Asistencia</h1>
      <p class="page-subtitle">Tu presencia es el mejor regalo que podemos recibir.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="confirm-wrap">
        <div class="confirm-icon" aria-hidden="true">💌</div>

        <p class="confirm-message">
          Solicitamos atentamente tu respuesta antes del <strong>15 de agosto de 2026</strong>.
        </p>

        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSfn3NKC_SFPmLEkvCzREwg_8ZUGn0HnqTaJSQiSwI6jxBIvXQ/viewform"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-confirm"
          data-track="cta_confirmar"
          data-ubicacion="pagina_confirmar"
        >
          Confirmar asistencia
        </a>

        <p class="confirm-thanks">
          Gracias por ser parte de nuestra historia ¡Salud! 🥂
        </p>

        <div class="confirm-contact">
          <p>¿Tienes alguna duda? Escríbenos por WhatsApp:</p>
          <div class="confirm-whatsapp">
            <a
              href="https://wa.me/56982218416?text=Hola%20Marlene%2C%20tengo%20una%20consulta%20sobre%20la%20boda"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp"
              data-track="cta_whatsapp"
              data-persona="marlene"
              data-ubicacion="pagina_confirmar"
            >
              📱 Marlene
            </a>
            <a
              href="https://wa.me/56951117662?text=Hola%20Carlos%2C%20tengo%20una%20consulta%20sobre%20la%20boda"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp"
              data-track="cta_whatsapp"
              data-persona="carlos"
              data-ubicacion="pagina_confirmar"
            >
              📱 Carlos
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(160deg, var(--color-blush) 0%, var(--color-cream) 100%);
    padding: 5rem 1.5rem 3rem;
    text-align: center;
  }

  .page-hero h1 { font-size: clamp(2.2rem, 6vw, 4rem); margin-bottom: 1rem; }

  .page-subtitle {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-accent);
  }

  .confirm-wrap {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .confirm-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  .confirm-message {
    font-size: 1.2rem;
    color: var(--color-dark);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .btn-confirm {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-light);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 1.1rem;
    padding: 1.1rem 3rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.25s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(184, 134, 11, 0.3);
  }

  .btn-confirm:hover {
    background: var(--color-dark);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .confirm-thanks {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-accent);
    margin-top: 2.5rem;
    margin-bottom: 3rem;
  }

  .confirm-contact {
    border-top: 1px solid #e8d8c4;
    padding-top: 2rem;
  }

  .confirm-contact p {
    font-size: 0.95rem;
    color: #6b5040;
    margin-bottom: 1rem;
  }

  .confirm-whatsapp {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-whatsapp {
    display: inline-block;
    border: 2px solid #25d366;
    color: #25d366;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.6rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.25s, color 0.25s;
  }

  .btn-whatsapp:hover {
    background: #25d366;
    color: white;
    text-decoration: none;
  }
</style>
